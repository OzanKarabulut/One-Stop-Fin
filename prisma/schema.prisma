generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Channel {
  id          String   @id @default(cuid())
  youtubeId   String   @unique
  name        String
  thumbnailUrl String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  videos      Video[]
}

model Video {
  id            String   @id @default(cuid())
  youtubeId     String   @unique
  channelId     String
  title         String
  publishedAt   DateTime
  thumbnailUrl  String?
  transcript    String?
  summary       String?
  sentiment     String?
  sentimentScore Float?
  processed     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  channel       Channel  @relation(fields: [channelId], references: [id])
  keyPoints     VideoKeyPoint[]
  stockMentions StockMention[]
}

model VideoKeyPoint {
  id        String @id @default(cuid())
  videoId   String
  point     String
  sentiment String?
  ticker    String?
  video     Video  @relation(fields: [videoId], references: [id])
}

model StockMention {
  id         String  @id @default(cuid())
  videoId    String
  ticker     String
  sentiment  String
  score      Float
  reasoning  String?
  video      Video   @relation(fields: [videoId], references: [id])

  @@index([ticker])
}

model TickerSignal {
  id        String   @id @default(cuid())
  ticker    String
  signal    String
  score     Float
  sources   Int      @default(0)
  date      DateTime @default(now())
  metadata  Json?

  @@index([ticker, date])
}

model WatchlistItem {
  id        String   @id @default(cuid())
  ticker    String   @unique
  name      String?
  addedAt   DateTime @default(now())
  notes     String?
}

model DailyReport {
  id        String   @id @default(cuid())
  date      DateTime @unique
  content   Json
  createdAt DateTime @default(now())
}

model UserPref {
  id           String @id @default("default")
  favorites    Json   @default("[]")
  theme        String @default("light")
  sidebarState Json   @default("{}")
}

model Position {
  id            Int       @id @default(autoincrement())
  ticker        String
  strategy      String    // "CSP" | "CC" | "WHEEL" | other
  optionType    String    // "put" | "call"
  strike        Float
  expiry        DateTime
  contracts     Int
  entryCredit   Float     // total premium received in USD (positive)
  predictedPwin Float?    // model's predicted win probability at entry, 0..1
  openedAt      DateTime  @default(now())
  status        String    @default("open") // "open" | "closed"
  closedAt      DateTime?
  exitDebit     Float?    // total USD paid to close (0 if expired worthless)
  realizedPnl   Float?
  notes         String?
  @@index([status])
}

model VolSnapshot {
  id     Int      @id @default(autoincrement())
  ticker String
  date   DateTime @default(now())
  atmIv  Float
  hv20   Float?
  @@unique([ticker, date])
  @@index([ticker])
}

model PredictionLog {
  id            Int      @id @default(autoincrement())
  ticker        String
  targetDate    DateTime
  madeOn        DateTime @default(now())
  madeOnDay     DateTime
  spot          Float
  sigmaUp       Float
  sigmaDown     Float
  tYears        Float
  median        Float
  skewComponent Float
  pinComponent  Float
  pointPrice    Float
  realized      Float?
  zScore        Float?
  @@unique([ticker, targetDate, madeOnDay])
  @@index([ticker])
}
